{
	"name": "@replit/codemirror-lang-csharp",
	"version": "6.2.0",
	"description": "A C# mode for CodeMirror 6",
	"license": "MIT",
	"author": {
		"name": "Alan Forshaw",
		"email": "alan@repl.it"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/replit/codemirror-lang-csharp.git"
	},
	"type": "module",
	"sideEffects": false,
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		"import": "./dist/index.js",
		"require": "./dist/index.cjs"
	},
	"scripts": {
		"dev": "npm run build && run-p dev-cm dev-vite",
		"dev-vite": "vite ./dev",
		"dev-cm": "node ./dev/watch.cjs src/index.ts",
		"build": "cm-buildhelper src/index.ts",
		"test": "mocha test/test-*.js",
		"publish": "npm run build && npm publish"
	},
	"devDependencies": {
		"@codemirror/autocomplete": "^6.0.0",
		"@codemirror/buildhelper": "^0.1.16",
		"@codemirror/language": "^6.0.0",
		"@codemirror/state": "^6.0.0",
		"@codemirror/theme-one-dark": "^6.0.0",
		"@codemirror/view": "^6.0.0",
		"@lezer/common": "^1.0.0",
		"@lezer/generator": "^1.0.0",
		"@lezer/highlight": "^1.0.0",
		"@lezer/lr": "^1.0.0",
		"codemirror": "^6.0.0",
		"mocha": "^10.2.0",
		"npm-run-all": "^4.1.5",
		"vite": "^2.3.8"
	},
	"peerDependencies": {
		"@codemirror/autocomplete": "^6.0.0",
		"@codemirror/language": "^6.0.0",
		"@codemirror/state": "^6.0.0",
		"@codemirror/view": "^6.0.0",
		"@lezer/common": "^1.0.0",
		"@lezer/highlight": "^1.0.0",
		"@lezer/lr": "^1.0.0"
	}
}
